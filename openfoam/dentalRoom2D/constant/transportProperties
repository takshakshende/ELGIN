FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Carrier phase: dry air at 20 C, 1 atm.
transportModel  Newtonian;

nu              nu  [0 2 -1 0 0 0 0]  1.5e-05;   // kinematic viscosity [m^2/s]
rho             rho [1 -3  0 0 0 0 0]  1.2;       // density [kg/m^3]

