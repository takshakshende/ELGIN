FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Inlet turbulent kinetic energy assuming 5% turbulence intensity at 0.5 m/s:
// k = 1.5 * (I * U)^2 = 1.5 * (0.05 * 0.5)^2 ~ 9.4e-04 m2/s2

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1e-03;

boundaryField
{
    airInlet
    {
        type            fixedValue;
        value           uniform 1e-03;
    }
    airOutlet
    {
        type            inletOutlet;
        inletValue      uniform 1e-03;
        value           uniform 1e-03;
    }
    floor           { type kqRWallFunction;   value uniform 1e-03; }
    ceiling         { type kqRWallFunction;   value uniform 1e-03; }
    leftWall        { type kqRWallFunction;   value uniform 1e-03; }
    rightWall       { type kqRWallFunction;   value uniform 1e-03; }
    frontAndBack    { type empty; }
}

// ************************************************************************* //
