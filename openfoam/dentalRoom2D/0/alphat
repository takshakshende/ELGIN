FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alphat;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    airOutlet
    {
        type            calculated;
        value           uniform 0;
    }
    floor
    {
        type            alphatWallFunction;
        Prt             0.85;
        value           uniform 0;
    }
    ceiling
    {
        type            alphatWallFunction;
        Prt             0.85;
        value           uniform 0;
    }
    airInlet
    {
        type            calculated;
        value           uniform 0;
    }
    leftWall
    {
        type            alphatWallFunction;
        Prt             0.85;
        value           uniform 0;
    }
    rightWall
    {
        type            alphatWallFunction;
        Prt             0.85;
        value           uniform 0;
    }
    frontAndBack
    {
        type            empty;
    }
}


