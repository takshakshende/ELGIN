FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// omega = sqrt(k) / (Cmu^0.25 * L), with L ~ 0.07 * Dh ~ 0.07 m
// -> omega ~ sqrt(1e-3) / (0.548 * 0.07) ~ 0.82 1/s; use 1.0 as initial guess.

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 1.0;

boundaryField
{
    airInlet
    {
        type            fixedValue;
        value           uniform 1.0;
    }
    airOutlet
    {
        type            inletOutlet;
        inletValue      uniform 1.0;
        value           uniform 1.0;
    }
    floor           { type omegaWallFunction;  value uniform 1.0; }
    ceiling         { type omegaWallFunction;  value uniform 1.0; }
    leftWall        { type omegaWallFunction;  value uniform 1.0; }
    rightWall       { type omegaWallFunction;  value uniform 1.0; }
    frontAndBack    { type empty; }
}

// ************************************************************************* //
