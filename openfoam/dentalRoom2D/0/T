FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    airInlet
    {
        type            fixedValue;
        value           uniform 300;
    }
    airOutlet
    {
        type            inletOutlet;
        inletValue      uniform 300;
        value           uniform 300;
    }
    floor
    {
        type            zeroGradient;
    }
    ceiling
    {
        type            zeroGradient;
    }
    leftWall
    {
        type            zeroGradient;
    }
    rightWall
    {
        type            zeroGradient;
    }
    frontAndBack
    {
        type            empty;
    }
}

